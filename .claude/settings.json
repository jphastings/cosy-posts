{
  "permissions": {
    "allow": [
      "Bash(beans *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git merge *)",
      "Bash(/opt/homebrew/bin/beans *)",
      "Bash(go *)",
      "Bash(swift *)",
      "Bash(xcodebuild *)",
      "Bash(xcrun *)",
      "WebFetch(domain:tus.github.io)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(echo \"exit: $?\")",
      "Bash(pkill -x CosyPostsAdmin)",
      "Bash(xc *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "beans prime"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "beans prime"
          }
        ]
      }
    ]
  }
}
