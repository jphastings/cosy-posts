{
  "name": "Access Requests — List, Approve, Deny",
  "description": "Admin endpoints for managing account access requests. Requires 'post' role.",
  "endpoints": {
    "list": {
      "request": {
        "method": "GET",
        "path": "/api/access-requests",
        "headers": {
          "Authorization": "Bearer {session_token}"
        }
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "application/json"
        },
        "body": ["{email_string}"]
      }
    },
    "approve": {
      "request": {
        "method": "POST",
        "path": "/api/access-requests/{email}/approve",
        "headers": {
          "Authorization": "Bearer {session_token}"
        }
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {"ok": true}
      }
    },
    "deny": {
      "request": {
        "method": "DELETE",
        "path": "/api/access-requests/{email}",
        "headers": {
          "Authorization": "Bearer {session_token}"
        }
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {"ok": true}
      }
    }
  }
}
