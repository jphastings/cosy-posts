<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title or "chaos.awaits.us" }}</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  {{ content | safe }}
  <script>
  (function() {
    // --- SVG icons ---
    var ICONS = {
      whatsapp: '<svg viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>',
      signal: '<svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 15l-4-4 1.41-1.41L11 14.17l6.59-6.59L19 9l-8 8z"/></svg>',
      email: '<svg viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>'
    };

    // --- Members data from 11ty ---
    var MEMBERS = {{ members | dump | safe }};

    // --- Contact preference (localStorage) ---
    var PREF_KEY = 'contact-pref';
    var DEFAULT_PREF = 'whatsapp,signal,email';

    function getPref() {
      return (localStorage.getItem(PREF_KEY) || DEFAULT_PREF).split(',');
    }

    function setPref(list) {
      localStorage.setItem(PREF_KEY, list.join(','));
    }

    // Resolve the best contact method for an author given user's preference order.
    function resolveMethod(authorEmail) {
      var member = MEMBERS[authorEmail];
      if (!member) return null;
      var pref = getPref();
      for (var i = 0; i < pref.length; i++) {
        for (var j = 0; j < member.methods.length; j++) {
          if (member.methods[j].type === pref[i]) return member.methods[j];
        }
      }
      // Fallback: first available method (should always have email).
      return member.methods[0] || null;
    }

    // Build the full contact URL with pre-filled message where supported.
    function buildContactURL(method, postURL) {
      var fullURL = location.origin + postURL;
      if (method.type === 'whatsapp') {
        var num = method.url.replace(/.*wa\.me\//, '').replace(/[^0-9]/g, '');
        return 'https://wa.me/' + num + '?text=' + encodeURIComponent('Hey! Saw your post: ' + fullURL);
      }
      if (method.type === 'signal') {
        return method.url;
      }
      if (method.type === 'email') {
        return 'mailto:' + method.url + '?subject=' + encodeURIComponent('Your post') + '&body=' + encodeURIComponent('Hey! Saw your post: ' + fullURL);
      }
      return '#';
    }

    // Update all contact buttons on the page.
    function updateContactButtons() {
      document.querySelectorAll('.contact-btn').forEach(function(btn) {
        var author = btn.getAttribute('data-author');
        var postURL = btn.getAttribute('data-post-url');
        var method = resolveMethod(author);
        if (!method) return;
        btn.href = buildContactURL(method, postURL);
        btn.setAttribute('data-method', method.type);
        btn.querySelector('.contact-icon').innerHTML = ICONS[method.type] || '';
      });
    }

    // Update the header preference icon to show the current top preference.
    function updatePrefIcon() {
      var icon = document.querySelector('.contact-pref-icon');
      if (!icon) return;
      var pref = getPref();
      icon.innerHTML = ICONS[pref[0]] || '';
    }

    // Header toggle: rotate the preference list (move first to end).
    var prefBtn = document.querySelector('.contact-pref-btn');
    if (prefBtn) {
      prefBtn.addEventListener('click', function() {
        var pref = getPref();
        pref.push(pref.shift());
        setPref(pref);
        updatePrefIcon();
        updateContactButtons();
      });
    }

    updatePrefIcon();
    updateContactButtons();

    // --- Carousel ---
    document.querySelectorAll('.carousel').forEach(function(c) {
      var track = c.querySelector('.carousel-track');
      var dots = c.querySelectorAll('.dot');
      var prev = c.querySelector('.carousel-prev');
      var next = c.querySelector('.carousel-next');
      if (!track) return;

      var update = function() {
        var i = Math.round(track.scrollLeft / track.offsetWidth);
        dots.forEach(function(d, j) { d.classList.toggle('active', j === i); });
        if (prev) prev.disabled = i === 0;
        if (next) next.disabled = i >= dots.length - 1;
      };

      track.addEventListener('scroll', update);
      if (prev) prev.addEventListener('click', function() {
        track.scrollBy({ left: -track.offsetWidth, behavior: 'smooth' });
      });
      if (next) next.addEventListener('click', function() {
        track.scrollBy({ left: track.offsetWidth, behavior: 'smooth' });
      });
      update();
    });
  })();
  </script>
</body>
</html>
