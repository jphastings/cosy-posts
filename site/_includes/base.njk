<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title or "chaos.awaits.us" }}</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  {{ content | safe }}
  <script>
  document.querySelectorAll('.carousel').forEach(c => {
    const track = c.querySelector('.carousel-track');
    const dots = c.querySelectorAll('.dot');
    const prev = c.querySelector('.carousel-prev');
    const next = c.querySelector('.carousel-next');
    if (!track) return;

    const update = () => {
      const i = Math.round(track.scrollLeft / track.offsetWidth);
      dots.forEach((d, j) => d.classList.toggle('active', j === i));
      if (prev) prev.disabled = i === 0;
      if (next) next.disabled = i >= dots.length - 1;
    };

    track.addEventListener('scroll', update);
    if (prev) prev.addEventListener('click', () => {
      track.scrollBy({ left: -track.offsetWidth, behavior: 'smooth' });
    });
    if (next) next.addEventListener('click', () => {
      track.scrollBy({ left: track.offsetWidth, behavior: 'smooth' });
    });
    update();
  });
  </script>
</body>
</html>
