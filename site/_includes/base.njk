<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title or "chaos.awaits.us" }}</title>
    <link rel="stylesheet" href="/css/style.css">
  </head>
  <body>
    {{ content | safe }}
    <script>
      (function () {
        var MEMBERS = {{ members | dump | safe }};
        var ALL_METHODS = ['whatsapp', 'signal', 'email'];
        var PREF_KEY = 'contact-pref';
        var DEFAULT_PREF = 'whatsapp,signal,email';
        function getPref() {
          return(localStorage.getItem(PREF_KEY) || DEFAULT_PREF).split(',').filter(Boolean);
        }
        function setPref(list) {
          localStorage.setItem(PREF_KEY, list.join(','));
        }
        // Resolve the best contact method for an author given user's preference order.
        function resolveMethod(authorEmail) {
          var member = MEMBERS[authorEmail];
          if (! member) 
            return null;
          
          var pref = getPref();
          for (var i = 0; i < pref.length; i++) {
            for (var j = 0; j < member.methods.length; j++) {
              if (member.methods[j].type === pref[i]) 
                return member.methods[j];
              
            }
          }
          return member.methods[0] || null;
        }
        function buildContactURL(method, postURL) {
          var fullURL = location.origin + postURL;
          if (method.type === 'whatsapp') {
            var num = method
              .url
              .replace(/.*wa\.me\//, '')
              .replace(/[^0-9]/g, '');
            return 'https://wa.me/' + num + '?text=' + encodeURIComponent(`.\n\n${fullURL}`);
          }
          if (method.type === 'signal') 
            return method.url;
          
          if (method.type === 'email') {
            return 'mailto:' + method.url + '?body=' + encodeURIComponent(`.\n\n${fullURL}`);
          }
          return method.url;
        }
        function updateContactButtons() {
          document.querySelectorAll('.contact-btn').forEach(function (btn) {
            var author = btn.getAttribute('data-author');
            var postURL = btn.getAttribute('data-post-url');
            var method = resolveMethod(author);
            if (! method) 
              return;
            
            btn.href = buildContactURL(method, postURL);
            btn.setAttribute('data-method', method.type);
            var img = btn.querySelector('.contact-icon img');
            if (img) 
              img.src = '/img/' + method.type + '.svg';
            
          });
        }
        // --- Contact preference dialog ---
        var METHOD_NAMES = { whatsapp: 'WhatsApp', signal: 'Signal', email: 'Email' };
        var prefBtn = document.querySelector('.contact-pref-btn');
        var prefDialog = document.querySelector('.contact-pref-dialog');
        var prefList = prefDialog ? prefDialog.querySelector('.pref-list') : null;
        var prefCloseBtn = prefDialog ? prefDialog.querySelector('.pref-dialog-close') : null;

        function syncPrefBtnIcon() {
          if (!prefBtn) return;
          var pref = getPref();
          var img = prefBtn.querySelector('img');
          if (img && pref.length > 0) img.src = '/img/' + pref[0] + '.svg';
        }

        function getOrderedMethods() {
          var pref = getPref();
          var unchecked = ALL_METHODS.filter(function (m) {
            return pref.indexOf(m) === -1;
          }).sort();
          return pref.map(function (m) { return { method: m, checked: true }; })
            .concat(unchecked.map(function (m) { return { method: m, checked: false }; }));
        }

        function renderPrefList() {
          if (!prefList) return;
          prefList.innerHTML = '';
          var items = getOrderedMethods();
          items.forEach(function (item) {
            var li = document.createElement('li');
            li.setAttribute('data-method', item.method);
            li.draggable = true;
            if (!item.checked) li.classList.add('unchecked');

            var handle = document.createElement('span');
            handle.className = 'pref-drag-handle';
            handle.textContent = '\u2630';

            var icon = document.createElement('span');
            icon.className = 'pref-icon';
            icon.innerHTML = '<img src="/img/' + item.method + '.svg" alt="">';

            var label = document.createElement('span');
            label.className = 'pref-label';
            label.textContent = METHOD_NAMES[item.method] || item.method;

            var check = document.createElement('input');
            check.type = 'checkbox';
            check.className = 'pref-check';
            check.checked = item.checked;
            if (item.method === 'email') { check.checked = true; check.disabled = true; }

            li.appendChild(handle);
            li.appendChild(icon);
            li.appendChild(label);
            li.appendChild(check);
            prefList.appendChild(li);

            // Checkbox toggle
            check.addEventListener('change', function () {
              var pref = getPref();
              if (check.checked) {
                if (pref.indexOf(item.method) === -1) pref.push(item.method);
              } else {
                var idx = pref.indexOf(item.method);
                if (idx !== -1 && pref.length > 1) pref.splice(idx, 1);
                else { check.checked = true; return; }
              }
              setPref(pref);
              updateContactButtons();
              syncPrefBtnIcon();
              renderPrefList();
            });
          });
        }

        // Drag and drop reorder
        var dragItem = null;
        if (prefList) {
          prefList.addEventListener('dragstart', function (e) {
            var li = e.target.closest('li');
            if (!li) return;
            dragItem = li;
            li.classList.add('dragging');
            e.dataTransfer.effectAllowed = 'move';
          });
          prefList.addEventListener('dragend', function () {
            if (dragItem) dragItem.classList.remove('dragging');
            prefList.querySelectorAll('li').forEach(function (li) {
              li.classList.remove('drag-over');
            });
            dragItem = null;
          });
          prefList.addEventListener('dragover', function (e) {
            e.preventDefault();
            e.dataTransfer.dropEffect = 'move';
            var li = e.target.closest('li');
            prefList.querySelectorAll('li').forEach(function (el) {
              el.classList.remove('drag-over');
            });
            if (li && li !== dragItem) li.classList.add('drag-over');
          });
          prefList.addEventListener('drop', function (e) {
            e.preventDefault();
            var target = e.target.closest('li');
            if (!target || !dragItem || target === dragItem) return;
            // Build new order from DOM
            var allLi = Array.from(prefList.querySelectorAll('li'));
            var fromIdx = allLi.indexOf(dragItem);
            var toIdx = allLi.indexOf(target);
            allLi.splice(fromIdx, 1);
            allLi.splice(toIdx, 0, dragItem);
            // Derive new pref: checked items in new order, unchecked sorted to bottom
            var pref = getPref();
            var newPref = [];
            allLi.forEach(function (li) {
              var m = li.getAttribute('data-method');
              if (pref.indexOf(m) !== -1) newPref.push(m);
            });
            // Ensure email is always in pref
            if (newPref.indexOf('email') === -1) newPref.push('email');
            setPref(newPref);
            updateContactButtons();
            syncPrefBtnIcon();
            renderPrefList();
          });
        }

        // Open/close dialog
        if (prefBtn && prefDialog) {
          prefBtn.addEventListener('click', function () {
            renderPrefList();
            prefDialog.showModal();
          });
          prefCloseBtn.addEventListener('click', function () {
            prefDialog.close();
          });
          prefDialog.addEventListener('click', function (e) {
            if (e.target === prefDialog) prefDialog.close();
          });
        }
        syncPrefBtnIcon();
        updateContactButtons();
        // --- Bookmarks ---
        var BM_KEY = 'bookmarks';
        function getBookmarks() {
          try {
            return JSON.parse(localStorage.getItem(BM_KEY)) || [];
          } catch (e) {
            return [];
          }
        }
        function setBookmarks(ids) {
          localStorage.setItem(BM_KEY, JSON.stringify(ids));
        }
        function updateBookmarkIcons() {
          var bm = getBookmarks();
          document.querySelectorAll('.bookmark-btn').forEach(function (btn) {
            var post = btn.closest('.post');
            if (! post) 
              return;
            
            var id = post.getAttribute('data-post-id');
            var img = btn.querySelector('img');
            if (img) 
              img.src = bm.indexOf(id) !== -1
                ? '/img/bookmarked.svg'
                : '/img/bookmark.svg';
            
          });
        }
        document.querySelectorAll('.bookmark-btn').forEach(function (btn) {
          btn.addEventListener('click', function () {
            var post = btn.closest('.post');
            if (! post) 
              return;
            
            var id = post.getAttribute('data-post-id');
            var bm = getBookmarks();
            var idx = bm.indexOf(id);
            if (idx !== -1) 
              bm.splice(idx, 1);
             else 
              bm.push(id);
             setBookmarks(bm);
            updateBookmarkIcons();
            updateFilterBtnVisibility();
            if (bookmarkFiltering) 
              applyBookmarkFilter();
            
          });
        });
        updateBookmarkIcons();
        // --- Bookmark filter (header) ---
        var bookmarkFiltering = false;
        var filterBtn = document.querySelector('.bookmark-filter-btn');
        var filterLabel = filterBtn
          ? filterBtn.querySelector('.bookmark-filter-label')
          : null;
        function updateFilterBtnVisibility() {
          if (! filterBtn) 
            return;
          
          var hasBookmarks = getBookmarks().length > 0;
          filterBtn.classList.toggle('visible', hasBookmarks || bookmarkFiltering);
          if (! hasBookmarks && bookmarkFiltering) {
            bookmarkFiltering = false;
            filterBtn.classList.remove('active');
            var img = filterBtn.querySelector('img');
            if (img) 
              img.src = '/img/bookmark.svg';
            
            if (filterLabel) 
              filterLabel.textContent = '';
            
            applyBookmarkFilter();
          }
        }
        function applyBookmarkFilter() {
          var bm = getBookmarks();
          document.querySelectorAll('.post').forEach(function (post) {
            var id = post.getAttribute('data-post-id');
            post.style.display = (bookmarkFiltering && bm.indexOf(id) === -1)
              ? 'none'
              : '';
          });
        }
        if (filterBtn) {
          filterBtn.addEventListener('click', function () {
            bookmarkFiltering = ! bookmarkFiltering;
            filterBtn.classList.toggle('active', bookmarkFiltering);
            var img = filterBtn.querySelector('img');
            if (img) 
              img.src = bookmarkFiltering
                ? '/img/bookmarked.svg'
                : '/img/bookmark.svg';
            
            if (filterLabel) 
              filterLabel.textContent = bookmarkFiltering
                ? 'Only bookmarked'
                : '';
            
            applyBookmarkFilter();
          });
        }
        updateFilterBtnVisibility();
        // --- Carousel ---
        document.querySelectorAll('.carousel').forEach(function (c) {
          var track = c.querySelector('.carousel-track');
          var dots = c.querySelectorAll('.dot');
          var prev = c.querySelector('.carousel-prev');
          var next = c.querySelector('.carousel-next');
          if (! track) 
            return;
          
          var update = function () {
            var i = Math.round(track.scrollLeft / track.offsetWidth);
            dots.forEach(function (d, j) {
              d.classList.toggle('active', j === i);
            });
            if (prev) 
              prev.disabled = i === 0;
            
            if (next) 
              next.disabled = i >= dots.length - 1;
            
          };
          track.addEventListener('scroll', update);
          if (prev) 
            prev.addEventListener('click', function () {
              track.scrollBy({
                left: - track.offsetWidth,
                behavior: 'smooth'
              });
            });
          
          if (next) 
            next.addEventListener('click', function () {
              track.scrollBy({left: track.offsetWidth, behavior: 'smooth'});
            });
          
          update();
        });
      })();
    </script>
  </body>
</html>