---
layout: base.njk
title: chaos.awaits.us
---

<header class="site-header">
  <h1>chaos.awaits.us</h1>
  <select class="contact-pref-select" aria-label="Contact method preferences">
    <option value="whatsapp"><img src="/img/whatsapp.svg" alt=""> WhatsApp</option>
    <option value="signal"><img src="/img/signal.svg" alt=""> Signal</option>
    <option value="email"><img src="/img/email.svg" alt=""> Email</option>
  </select>
</header>

<main class="feed">
  {% for post in posts %}
  {% include "post-card.njk" %}
  {% endfor %}

  {% if posts.length == 0 %}
  <p class="empty">No posts yet.</p>
  {% endif %}
</main>
