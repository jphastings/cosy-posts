---
layout: base.njk
title: chaos.awaits.us
---

<header class="site-header">
  <h1>chaos.awaits.us</h1>
  <button class="bookmark-filter-btn" aria-label="Show bookmarked posts">
    <span class="bookmark-filter-label"></span>
    <img src="/img/bookmark.svg" alt="">
  </button>
  <button class="contact-pref-btn" aria-label="Contact preferences">
    <img src="/img/whatsapp.svg" alt="">
  </button>
</header>

<dialog class="contact-pref-dialog">
  <div class="pref-dialog-header">
    <span class="pref-dialog-title">Choose your preferred messenger</span>
    <button class="pref-dialog-close" aria-label="Close">&times;</button>
  </div>
  <ul class="pref-list"></ul>
</dialog>

<main class="feed">
  {% for post in posts %}
  {% include "post-card.njk" %}
  {% endfor %}

  {% if posts.length == 0 %}
  <p class="empty">No posts yet.</p>
  {% endif %}
</main>
